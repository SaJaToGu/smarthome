# AIS Orchestrator — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# GitHub Token: wird via SSH von iMac2 geholt (sicher, nicht hier gespeichert)
# OpenRouter API Key: erforderlich — bekommst du kostenlos bei https://openrouter.ai/credits
# ═══════════════════════════════════════════════════════════════

# GitHub (via iMac2 token — wird via wrapper gezogen, nicht hier)
# GITHUB_TOKEN=gho_xxx

# OpenRouter — trage deinen Key hier ein, sobald du einen hast
# OPENROUTER_API_KEY=sk-or-v1-xxx

# Modell-Routing (für Node-RED-Flows = high-risk, braucht stärkeres Modell)
# Default ist minimax/minimax-m3 (solver), für komplexe Flows:
AIS_DEFAULT_MODEL=minimax/minimax-m3
AIS_NODE_RED_MODEL=anthropic/claude-sonnet-4

# Logging
AIS_LOG_LEVEL=INFO
AIS_DRY_RUN=false

# Repository
AIS_TARGET_REPO=SaJaToGu/smarthome
AIS_ORCHESTRATOR_BRANCH=develop
